# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ---------------------------------------------------------------
# Django core
# ---------------------------------------------------------------

# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to false in production
DJANGO_DEBUG=false

# Space-separated list of allowed hosts
# Production example: yourdomain.com www.yourdomain.com
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Path where the Django admin is mounted. REQUIRED when DJANGO_DEBUG=false
# (the app will refuse to start without it). Pick a unique, non-guessable
# value — do not use "admin/". Example generator:
#   python -c "import secrets; print(f'manage-{secrets.token_hex(8)}/')"
DJANGO_ADMIN_URL=

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------

# Local development: leave DB_ENGINE as sqlite3 and DB_NAME empty (uses db.sqlite3)
# MySQL:
#   DB_ENGINE=django.db.backends.mysql
#   DB_NAME=your_db_name
#   DB_USER=your_db_user        (use a dedicated, least-privilege user — not root)
#   DB_PASSWORD=your_db_password
#   DB_HOST=127.0.0.1
#   DB_PORT=3306
DB_ENGINE=django.db.backends.mysql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# TLS for the MySQL connection. REQUIRED (default) encrypts the connection;
# DISABLED turns off TLS entirely (only for a trusted local-only DB).
# Set DB_SSL_CA to a CA bundle path to verify the server certificate too
# (then also set DB_SSL_MODE=VERIFY_CA or VERIFY_IDENTITY).
DB_SSL_MODE=REQUIRED
DB_SSL_CA=

# ---------------------------------------------------------------
# Email
# ---------------------------------------------------------------

# Local development: console backend prints emails to stdout instead of sending them
# Production (SMTP): use django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Inbox that receives account deletion request notifications (see
# company_accounts views/docs/gdpr_compliance.md). REQUIRED in production —
# if unset, deletion requests are submitted but no one is notified.
SUPPORT_EMAIL=

# ---------------------------------------------------------------
# Rate limiting (django-ratelimit)
# ---------------------------------------------------------------

# WSGI META key django-ratelimit reads the client IP from. Leave unset
# (defaults to REMOTE_ADDR) unless running behind a reverse proxy that you
# have configured to always overwrite this header itself — otherwise an
# attacker can spoof it to bypass all rate limits. See docs/deployment.md.
RATELIMIT_IP_META_KEY=
